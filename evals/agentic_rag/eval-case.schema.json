{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zotero-web-library.local/schemas/agentic-rag-eval-v1.json",
  "title": "Agentic RAG evaluation suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite_id", "cases"],
  "properties": {
    "schema_version": {"const": "agentic-rag-eval/v1"},
    "suite_id": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "default_top_k": {"type": "integer", "minimum": 1, "maximum": 30},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "knowledge_base_name": {"type": "string", "minLength": 1},
        "item_keys": {"$ref": "#/$defs/stringList"}
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_results": {"type": "integer", "minimum": 0},
        "max_results": {"type": "integer", "minimum": 0},
        "min_distinct_items": {"type": "integer", "minimum": 0},
        "required_item_keys": {"$ref": "#/$defs/stringList"},
        "any_item_keys": {"$ref": "#/$defs/stringList"},
        "excluded_item_keys": {"$ref": "#/$defs/stringList"},
        "allowed_item_keys": {"$ref": "#/$defs/stringList"},
        "required_warnings": {"$ref": "#/$defs/stringList"},
        "forbidden_warnings": {"$ref": "#/$defs/stringList"},
        "required_sections": {"$ref": "#/$defs/stringList"},
        "answer_contains": {"$ref": "#/$defs/stringList"}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "question", "task_type", "expected"],
      "properties": {
        "case_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
        "question": {"type": "string", "minLength": 1},
        "task_type": {
          "enum": ["factual", "summary", "comparative", "matrix", "writing", "scope", "negative"]
        },
        "mode": {"enum": ["auto", "hybrid", "metadata", "keyword", "semantic"]},
        "top_k": {"type": "integer", "minimum": 1, "maximum": 30},
        "scope": {"$ref": "#/$defs/scope"},
        "expected": {"$ref": "#/$defs/expected"},
        "tags": {"$ref": "#/$defs/stringList"},
        "notes": {"type": "string"}
      }
    }
  }
}
